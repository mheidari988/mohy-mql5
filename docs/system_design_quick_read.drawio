        <mxCell id="32" value="shared config mapping" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#455A64;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="12" target="10">
